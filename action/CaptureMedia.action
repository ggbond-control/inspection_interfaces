uint32 task_id
string mode                    # photo / video
string camera_type
uint32 recording_seconds        # 录像时长(秒)，0表示持续录像直到收到停止命令
uint32 photo_count
float32 photo_interval_seconds
float32 focal_length
float32 zoom_level
bool start_recording           # 仅在 mode=video 时有效: true=开始录像, false=停止录像
---
bool success
string error_message
string[] media_uris
---
string state
float32 progress
